# OpenRouter API key — enables server-side AI (notification parsing + receipt OCR).
OPENROUTER_API_KEY=

# Optional: pin the vision model used for receipt OCR. Default "openrouter/free"
# auto-selects a free vision-capable model. Set to a specific (paid) model id to
# avoid free-tier rate limits / variability, e.g. openai/gpt-4o-mini.
OCR_MODEL=

# Optional: paid fallback model tried ONLY when the free OCR attempt fails (e.g. the
# free tier is rate-limited / 429). Recommended: google/gemini-2.5-flash-lite
# (~$0.0002/scan — efficient image tokenization). AVOID openai/gpt-4o-mini (~$0.006/scan:
# it bills images at a ~33x token multiplier). Requires OpenRouter credits. Empty = free-only.
OCR_FALLBACK_MODEL=
