# OpenRouter API key — enables server-side AI (notification parsing + receipt OCR).
OPENROUTER_API_KEY=

# Optional: pin the vision model used for receipt OCR. Default "openrouter/free"
# auto-selects a free vision-capable model. Set to a specific (paid) model id to
# avoid free-tier rate limits / variability, e.g. openai/gpt-4o-mini.
OCR_MODEL=
